{
  "name": "@enlight/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenv -e ../../.env -- tsx watch src/index.ts",
    "build": "tsc",
    "start": "dotenv -e ../../.env -- node dist/index.js",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "migrate": "dotenv -e ../../.env -- drizzle-kit migrate",
    "migrate:generate": "dotenv -e ../../.env -- drizzle-kit generate",
    "migrate:run": "node dist/db/migrate.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.0",
    "@aws-sdk/client-s3": "^3.1057.0",
    "@aws-sdk/lib-storage": "^3.1057.0",
    "@aws-sdk/s3-request-presigner": "^3.1057.0",
    "@enlight/shared": "workspace:*",
    "@google-cloud/storage": "^7.19.0",
    "@slack/bolt": "^4.0.0",
    "@slack/web-api": "^7.0.0",
    "bcrypt": "^5.1.0",
    "bullmq": "^5.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "drizzle-orm": "^0.38.0",
    "express": "^4.21.0",
    "express-rate-limit": "^7.0.0",
    "express-session": "^1.18.0",
    "googleapis": "^173.0.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.0.0",
    "jsonwebtoken": "^9.0.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.10",
    "passport": "^0.7.0",
    "passport-saml": "^3.2.0",
    "pg": "^8.11.0",
    "qrcode": "^1.5.4",
    "uuid": "^10.0.0",
    "winston": "^3.11.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/cors": "^2.8.0",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.18.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/multer": "^1.4.0",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^8.0.0",
    "@types/passport": "^1.0.0",
    "@types/passport-saml": "^1.1.7",
    "@types/pg": "^8.11.0",
    "@types/qrcode": "^1.5.6",
    "@types/uuid": "^10.0.0",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
