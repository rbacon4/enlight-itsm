# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://enlight:enlight@localhost:5432/enlight

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── AI platform ───────────────────────────────────────────────────────────────
# The agent's LLM provider is chosen per-org in Settings → AI Keys (Anthropic or
# OpenAI). AI_PROVIDER sets the DEFAULT platform for orgs that haven't chosen one
# (e.g. set by the deploy tool); the in-app setting always overrides it.
# AI_PROVIDER=anthropic   # or "openai"
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...   # used when the AI platform is set to OpenAI (or OpenAI embeddings)

# ── Embeddings (for knowledge base semantic search) ───────────────────────────
# Provider: 'voyage' (default, voyage-large-2, 1536 dims — Anthropic's recommended partner)
#        or 'openai' (text-embedding-3-small, 1536 dims)
EMBEDDING_PROVIDER=voyage
VOYAGE_API_KEY=pa-...

# ── Slack ─────────────────────────────────────────────────────────────────────
# Two connection modes:
#   • Local dev  → Socket Mode (no public URL). Needs SLACK_APP_TOKEN below.
#   • Production → standard HTTP + OAuth (NODE_ENV=production). Socket Mode is
#     disabled automatically; the API exposes /slack/events, /slack/install,
#     /slack/oauth_redirect. See CLAUDE.md → "Production deployment" for the
#     Request URL / redirect URL you configure in the Slack app dashboard.
SLACK_BOT_TOKEN=xoxb-...        # single-workspace token mode (optional once OAuth is set up)
SLACK_SIGNING_SECRET=...        # required in all modes (verifies inbound requests)
SLACK_APP_TOKEN=xapp-...        # Socket Mode app-level token (local dev only)

# Production OAuth ("Distribute App" / multi-install). Required for the HTTP
# install flow; leave blank in dev. With these set, self-hosters install the bot
# by visiting  https://<your-host>/slack/install.
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
# Secret used to sign the OAuth state param. Falls back to JWT_SECRET if unset.
SLACK_STATE_SECRET=
# Optional explicit OAuth redirect URL. If unset, Bolt derives it from the
# request host as  https://<your-host>/slack/oauth_redirect  — set it explicitly
# when behind a proxy/load balancer that rewrites the host.
SLACK_REDIRECT_URI=

# ── Auth / Sessions ───────────────────────────────────────────────────────────
SESSION_SECRET=change-me-in-production
JWT_SECRET=change-me-in-production
# 32-byte key (64 hex chars) for encrypting stored provider secrets at rest.
# Generate with:  openssl rand -hex 32
# If unset, a key is derived from JWT_SECRET (fine for dev; set a dedicated key in production).
SECRETS_ENCRYPTION_KEY=

# ── App URLs ──────────────────────────────────────────────────────────────────
API_URL=http://localhost:3000
WEB_URL=http://localhost:5173
MCP_URL=http://localhost:3001

# ── GCS (production only; leave empty for local dev) ─────────────────────────
GCS_BUCKET_NAME=
GCS_PROJECT_ID=

# ── Email (optional; required for SLA breach email alerts) ───────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=alerts@example.com
EMAIL_FROM_NAME=Enlight Alerts

# ── Google Cloud / Workspace offboarding (optional) ─────────────────────────
# Preferred: configure everything in the web portal (Settings → Google Cloud +
# Offboarding + Slack). Those per-org settings take precedence over these env
# vars, which exist only as a fallback. A single GCP project / service account
# backs all Google features. Leave the service-account JSON unset to run in mock
# mode (no real Google API calls) — useful for demos and local development.
# GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...", ...}'
GCS_PROJECT_ID=                    # the shared GCP project ID
GOOGLE_ADMIN_EMAIL=                # super admin to impersonate (domain-wide delegation)
GOOGLE_DOMAIN=                     # e.g. acme.com
DEPARTED_OU_PATH=/Departed Employees
ARCHIVE_OU_PATH=                   # optional; enables the Archive option
OFFBOARDING_AUDIT_CHANNEL=         # Slack channel for audit summaries (e.g. #it-offboarding-audit)
MOCK_GOOGLE_API=                   # set "true" to force mock mode

# ── Automated Postgres backups (optional; worker nightly job) ────────────────
# When BACKUP_S3_BUCKET is set, the worker schedules a nightly pg_dump → gzip →
# upload to any S3-compatible bucket (AWS S3, GCS via its S3 interop endpoint, or
# DigitalOcean Spaces). Leave the bucket empty to disable backups entirely.
BACKUP_S3_BUCKET=
BACKUP_S3_REGION=us-east-1
# Custom endpoint for non-AWS S3-compatible stores (path-style is auto-enabled
# when set). Examples:
#   GCS    → https://storage.googleapis.com
#   Spaces → https://nyc3.digitaloceanspaces.com
BACKUP_S3_ENDPOINT=
BACKUP_S3_ACCESS_KEY_ID=
BACKUP_S3_SECRET_ACCESS_KEY=
BACKUP_S3_PREFIX=enlight-backups       # key prefix (folder) inside the bucket
BACKUP_CRON=0 3 * * *                  # nightly at 03:00 (node-cron / BullMQ pattern)
# Override the pg_dump binary path. Use this if the container's pg_dump major
# version is older than your Postgres server (otherwise pg_dump refuses to run).
BACKUP_PGDUMP_PATH=

# ── Licensing (disabled by default — pre-release) ────────────────────────────
# The license-key feature is OFF unless LICENSE_ENFORCEMENT is exactly "true".
# While off: the Settings → License tab is hidden, the boot log notes it's
# disabled, and the app runs unrestricted. Flip to "true" at GA and point
# LICENSE_PUBLIC_KEY at your hosted license server's public key.
LICENSE_ENFORCEMENT=false
# Ed25519 public key (hex) used to verify license keys offline. Get it from your
# license server's  GET /public/key  endpoint. Only needed when enforcement is on.
LICENSE_PUBLIC_KEY=

# ── Environment ───────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug
PORT=3000
MCP_PORT=3001
# Production single-container deploy (Dockerfile.prod): the API serves the built
# React SPA and mounts all REST routes under /api. Point the browser/build at the
# same origin; override the static dir only if you relocate the build output.
# WEB_DIST_DIR=/app/packages/web/dist

# ── Updates (Settings → Updates) ──────────────────────────────────────────────
# The build commit, so the app can tell when a newer version is available. The
# deploy tool sets this automatically to the deployed commit SHA.
# APP_COMMIT=
# Repo/branch the update check tracks (defaults below).
# UPDATE_REPO=rbacon4/enlight-itsm
# UPDATE_BRANCH=main
# A GitHub token — required for the update check ONLY if the repo is private.
# GITHUB_TOKEN=
